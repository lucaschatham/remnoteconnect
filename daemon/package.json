{
  "name": "@remnoteconnect/daemon",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "remnote-connect-daemon": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @remnoteconnect/shared build && tsc -p tsconfig.json --noEmit",
    "dev": "pnpm --filter @remnoteconnect/shared build && tsx src/index.ts",
    "start": "node dist/index.js",
    "token:unsafe": "pnpm --filter @remnoteconnect/shared build && tsx src/cli.ts token --unsafe-print",
    "test": "pnpm --filter @remnoteconnect/shared build && vitest run"
  },
  "dependencies": {
    "@remnoteconnect/shared": "workspace:*",
    "fastify": "^5.4.0",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "vitest": "^4.1.10"
  }
}
