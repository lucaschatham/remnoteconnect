{
  "id": "remnoteconnect-codex-local-v3",
  "name": "RemNoteConnect Codex Bridge",
  "author": "Lucas Chatham",
  "description": "Local bridge that lets terminal tools read, author, and safely operate on RemNote through reversible local controls.",
  "repoUrl": "https://github.com/your-org/remnoteconnect",
  "version": {
    "major": 0,
    "minor": 3,
    "patch": 0
  },
  "manifestVersion": 1,
  "requestNative": false,
  "enableOnMobile": false,
  "unlisted": true,
  "requiredScopes": [
    {
      "type": "All",
      "level": "ReadCreateModifyDelete"
    },
    {
      "type": "KnowledgeBaseInfo",
      "level": "Read"
    }
  ]
}
