{
  "name": "remnote-connect",
  "private": true,
  "version": "0.3.0",
  "description": "Local RemNote bridge for CLI, scripts, and LLM agents.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @remnoteconnect/daemon test",
    "dev:daemon": "pnpm --filter @remnoteconnect/daemon dev",
    "dev:plugin": "pnpm --filter @remnoteconnect/plugin dev",
    "token:unsafe": "pnpm --filter @remnoteconnect/daemon token:unsafe",
    "smoke": "node scripts/smoke.mjs",
    "e2e": "node scripts/e2e.mjs",
    "bench": "node scripts/bench.mjs",
    "anki:migrate": "node scripts/anki-migrate.mjs",
    "live:restore": "node scripts/live-restore.mjs",
    "live:security": "node scripts/live-security.mjs",
    "live:scope": "node scripts/live-scope.mjs",
    "live:softdelete": "node scripts/live-softdelete.mjs",
    "live:docs": "node scripts/live-docs.mjs",
    "live:anki-probes": "node scripts/live-anki-migration-probes.mjs",
    "live:cardtypes": "node scripts/live-cardtypes.mjs",
    "live:readonly": "node scripts/live-readonly.mjs",
    "probe:capabilities": "node scripts/probe-capabilities.mjs",
    "pilot:audit": "node scripts/pilot-audit.mjs",
    "obsidian:census": "node scripts/obsidian-census.mjs",
    "obsidian:flashcards": "node scripts/obsidian-flashcard-audit.mjs",
    "obsidian:flashcard-review-plan": "node scripts/obsidian-flashcard-review-plan.mjs",
    "obsidian:attachments": "node scripts/obsidian-attachment-audit.mjs",
    "obsidian:attachment-manifest": "node scripts/obsidian-attachment-manifest.mjs",
    "obsidian:attachment-capabilities": "node scripts/obsidian-attachment-capability-probe.mjs",
    "obsidian:attachment-transfer-plan": "node scripts/obsidian-attachment-transfer-plan.mjs",
    "obsidian:links": "node scripts/obsidian-link-normalization-audit.mjs --scope all",
    "obsidian:links-needs-review": "node scripts/obsidian-link-normalization-audit.mjs --scope approval",
    "obsidian:link-conversion-batch": "node scripts/obsidian-link-conversion-batch.mjs",
    "obsidian:child-map": "node scripts/obsidian-child-map-audit.mjs",
    "obsidian:link-execution-plan": "node scripts/obsidian-link-execution-plan.mjs",
    "obsidian:link-rewrite": "node scripts/obsidian-link-rewrite.mjs",
    "obsidian:link-rewrite-recovery-plan": "node scripts/obsidian-link-rewrite-recovery-plan.mjs",
    "obsidian:link-rewrite-chunked": "node scripts/obsidian-link-rewrite-chunked.mjs",
    "obsidian:content-audit": "node scripts/obsidian-content-completeness-audit.mjs",
    "obsidian:content-repair": "node scripts/obsidian-content-repair.mjs",
    "obsidian:needs-review": "node scripts/obsidian-needs-review-triage.mjs",
    "obsidian:needs-review-cleanup": "node scripts/obsidian-needs-review-cleanup-plan.mjs",
    "obsidian:empty-placeholders": "node scripts/obsidian-empty-placeholder-plan.mjs",
    "obsidian:approval-packet": "node scripts/obsidian-approval-packet.mjs",
    "obsidian:approved-write-window": "node scripts/obsidian-approved-write-window.mjs",
    "obsidian:backup-audit": "node scripts/obsidian-backup-audit.mjs",
    "obsidian:write-preflight": "node scripts/obsidian-write-preflight.mjs",
    "obsidian:search-index": "node scripts/obsidian-search-index.mjs",
    "obsidian:search": "node scripts/obsidian-search.mjs",
    "obsidian:completion": "node scripts/obsidian-migration-completion.mjs",
    "obsidian:wrapup-audit": "node scripts/obsidian-wrapup-audit.mjs",
    "obsidian:review-plan": "node scripts/obsidian-review-plan.mjs",
    "obsidian:plan-import": "node scripts/obsidian-import-plan.mjs",
    "obsidian:plan-clean-import": "node scripts/obsidian-import-plan.mjs --profile clean",
    "obsidian:plan-strict-import": "node scripts/obsidian-import-plan.mjs --profile strict",
    "obsidian:plan-approval-import": "node scripts/obsidian-import-plan.mjs --profile approval",
    "obsidian:execute-import": "node scripts/obsidian-import-execute.mjs",
    "obsidian:execute-clean-import": "node scripts/obsidian-import-execute.mjs --documents docs/obsidian-import-clean-documents.jsonl --cards docs/obsidian-import-clean-flashcards.json",
    "obsidian:execute-strict-import": "node scripts/obsidian-import-execute.mjs --documents docs/obsidian-import-strict-documents.jsonl --cards docs/obsidian-import-strict-flashcards.json",
    "obsidian:execute-approval-import": "node scripts/obsidian-import-execute.mjs --documents docs/obsidian-import-approval-documents.jsonl --cards docs/obsidian-import-approval-flashcards.json --result docs/obsidian-import-approval-execution.json --verification-result docs/obsidian-import-approval-execution-verification.json",
    "obsidian:verify-import": "node scripts/obsidian-import-verify.mjs",
    "obsidian:verify-clean-import": "node scripts/obsidian-import-verify.mjs --documents docs/obsidian-import-clean-documents.jsonl --cards docs/obsidian-import-clean-flashcards.json --result docs/obsidian-import-clean-verification.json",
    "obsidian:verify-strict-import": "node scripts/obsidian-import-verify.mjs --documents docs/obsidian-import-strict-documents.jsonl --cards docs/obsidian-import-strict-flashcards.json --result docs/obsidian-import-strict-verification.json",
    "obsidian:verify-approval-import": "node scripts/obsidian-import-verify.mjs --documents docs/obsidian-import-approval-documents.jsonl --cards docs/obsidian-import-approval-flashcards.json --result docs/obsidian-import-approval-verification.json",
    "live:cleanup": "node scripts/live-cleanup.mjs",
    "live:idempotent": "node scripts/live-idempotent.mjs",
    "live:scheduler": "node scripts/scheduler-smoke.mjs",
    "live:jobs": "node scripts/job-retention.mjs",
    "chaos:daemon": "node scripts/chaos-daemon.mjs",
    "chaos:async": "node scripts/chaos-async-job.mjs",
    "launch-agent:install": "node scripts/install-launch-agent.mjs install",
    "launch-agent:check": "node scripts/install-launch-agent.mjs check",
    "launch-agent:uninstall": "node scripts/install-launch-agent.mjs uninstall",
    "check:no-token": "node scripts/check-no-token.mjs",
    "check:redteam": "node scripts/static-redteam.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.8.3"
  }
}
